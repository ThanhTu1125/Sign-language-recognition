@startuml activity
title Sơ đồ hoạt động Hệ thống nhận diện Ngôn ngữ ký hiệu

start
:Người dùng truy cập trang Nhận diện;
:Hệ thống yêu cầu quyền Camera;

if (Đã cấp quyền?) then (Có)
    :Khởi tạo MediaPipe & Mở luồng Video;
    repeat
        :Chụp khung hình (Frame) từ Camera;
        :Xử lý ảnh qua detector.py;
        
        if (Tìm thấy bàn tay?) then (Có)
            :Trích xuất 21 điểm Landmarks;
            :Vẽ khung xương lên Frame;
            :Đưa tọa độ vào Model AI phân loại;
            :Hiển thị văn bản kết quả lên Web;
            
            if (Người dùng chọn "Lưu lịch sử"?) then (Có)
                :Gửi yêu cầu lưu vào MySQL;
                :Thông báo lưu thành công;
            else (Không)
                ' Merge node ngầm định của PlantUML tại endif
            endif
        else (Không)
            :Hiển thị thông báo "Không tìm thấy tay";
        endif
        
        ' Merge node - Điểm hội tụ của tất cả các nhánh rẽ
        label lab1
    repeat while (Người dùng chưa thoát trang?) is (Tiếp tục)
    ->Thoát;
else (Không)
    :Hiển thị lỗi: "Cần quyền truy cập Camera";
endif

stop
@enduml